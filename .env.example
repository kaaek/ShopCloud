POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shopcloud
POSTGRES_URL=jdbc:postgresql://postgres:5432/shopcloud?currentSchema=shopcloud

SHOPCLOUD_JWT_SECRET=change-me-to-a-very-long-secret-key-32-chars-minimum
SHOPCLOUD_INTERNAL_TOKEN=change-me-internal-token
SHOPCLOUD_ADMIN_BOOTSTRAP_KEY=change-me-admin-bootstrap-key
SHOPCLOUD_JWT_EXPIRATION_MS=86400000

PGADMIN_DEFAULT_EMAIL=admin@shopcloud.local
PGADMIN_DEFAULT_PASSWORD=admin123


