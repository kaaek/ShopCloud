# Admin Frontend Environment Configuration
# Copy this file to .env.local and fill in your values

# ————————— Cognito Configuration ————————— #
# Cognito User Pool ID (Admin Pool from Terraform outputs)
VITE_COGNITO_USER_POOL_ID=your_admin_user_pool_id_here

# Cognito App Client ID (Admin Client)
VITE_COGNITO_CLIENT_ID=your_admin_client_id_here

# Cognito Hosted UI Domain Prefix
VITE_COGNITO_DOMAIN=shopcloud-admin-your-suffix.auth.us-east-1.amazoncognito.com

# AWS Region
VITE_COGNITO_REGION=us-east-1

# OAuth Redirect URIs
# These must match the callback URLs configured in Cognito
VITE_REDIRECT_URI=https://admin.example.com/callback
VITE_REDIRECT_SIGN_OUT=https://admin.example.com

# For local development (accessible via VPN or port forwarding):
# VITE_REDIRECT_URI=http://localhost:3001/callback
# VITE_REDIRECT_SIGN_OUT=http://localhost:3001
