# Customer Frontend Environment Configuration
# Copy this file to .env.local and fill in your values

# ————————— Cognito Configuration ————————— #
# Cognito User Pool ID (Customer Pool from Terraform outputs)
VITE_COGNITO_USER_POOL_ID=your_customer_user_pool_id_here

# Cognito App Client ID (Customer Client)
VITE_COGNITO_CLIENT_ID=your_customer_client_id_here

# Cognito Hosted UI Domain Prefix
VITE_COGNITO_DOMAIN=shopcloud-customer-your-suffix.auth.us-east-1.amazoncognito.com

# AWS Region
VITE_COGNITO_REGION=us-east-1

# OAuth Redirect URIs
# These must match the callback URLs configured in Cognito
VITE_REDIRECT_URI=https://www.example.com/callback
VITE_REDIRECT_SIGN_OUT=https://www.example.com

# For local development:
# VITE_REDIRECT_URI=http://localhost:3000/callback
# VITE_REDIRECT_SIGN_OUT=http://localhost:3000
